{
  "name": "omnifetch",
  "version": "2.0.0",
  "description": "Unified content fetcher — WeChat / Xiaoyuzhou / Bilibili / Xiaohongshu / Zhihu, with yt-dlp fallback for video subtitles. CLI: of / omnifetch.",
  "type": "module",
  "bin": {
    "omnifetch": "./bin/omnifetch.js",
    "of": "./bin/omnifetch.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "SKILL.md"
  ],
  "scripts": {
