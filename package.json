    "dev": "tsx src/cli.ts",
    "test": "tsx --test test/**/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "defuddle": "^0.18.1",
    "linkedom": "^0.18.12"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.22.1",
    "typescript": "^5.3.0"
  },
  "optionalDependencies": {
    "playwright": "^1.40.0"
  }
}
